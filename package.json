{
  "name": "agent-human-log",
  "version": "0.1.0",
  "description": "Personal AI work companion — auto-captures, summarizes, and presents daily work for people who hate logging",
  "type": "module",
  "main": "dist/mcp-server/index.js",
  "bin": {
    "ahl": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/mcp-server/index.js",
    "daily": "tsc && node --env-file=.env dist/cli/index.js daily",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "better-sqlite3": "^11.0.0",
    "date-fns": "^4.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
